---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { projects } from "../../data/projects";
---

<BaseLayout lang="fr" title="Projets et publications | TeSE" description="Projets de recherche et publications selectionnees de TeSE.">
  <PageHero
    eyebrow="Projets et publications"
    title="Une recherche collaborative a l'interface des machines electriques, de la commande et de la mobilite durable."
    description="Cette page presente des directions de recherche, des projets collaboratifs et des publications selectionnees. Elle pourra ensuite etre connectee a HAL, ORCID ou a des exports BibTeX."
  />

  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-6 lg:grid-cols-3">
      {projects.fr.map((project) => (
        <article class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">{project.category}</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight text-slate-950">{project.title}</h2>
          <p class="mt-2 text-sm font-medium text-slate-500">{project.period}</p>
          <p class="mt-5 text-sm leading-7 text-slate-600">{project.summary}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 rounded-[2rem] bg-slate-950 p-8 text-white md:p-12">
      <h2 class="text-3xl font-semibold tracking-tight">Publications selectionnees</h2>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">
        La version de production de cette page devra inclure les articles de revue, communications, theses et liens ouverts. Une implementation pratique consiste a maintenir un fichier BibTeX ou a relier cette page a une collection HAL.
      </p>
    </div>
  </section>
</BaseLayout>
