---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Card from "../../components/Card.astro";
import { facilities } from "../../data/facilities";
---

<BaseLayout lang="fr" title="Plateformes | TeSE" description="Moyens experimentaux et plateformes de TeSE.">
  <PageHero
    eyebrow="Plateformes"
    title="Des moyens experimentaux pour tester, mesurer et valider les systemes electromecaniques."
    description="Nos plateformes couvrent l'ensemble du cycle de recherche : prototypage, commande, instrumentation, mesure, analyse et correlation modele-essai."
  />

  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {facilities.fr.map((facility) => (
        <Card title={facility.name} description={facility.description} />
      ))}
    </div>
  </section>
</BaseLayout>
