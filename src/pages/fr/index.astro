---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import { researchAxes } from "../../data/researchAxes";
---

<BaseLayout
  lang="fr"
  title="TeSE — Transducteurs et Systemes d'Energie"
  description="L'equipe TeSE developpe des methodes avancees pour les systemes de conversion electromecanique d'energie."
>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(37,99,235,0.16),_transparent_35%),radial-gradient(circle_at_bottom_left,_rgba(6,182,212,0.14),_transparent_35%)]"></div>
    <div class="relative mx-auto max-w-7xl px-6 py-28 md:py-36">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-600">Laboratoire SATIE</p>
      <h1 class="mt-6 max-w-5xl text-5xl font-semibold tracking-tight text-slate-950 md:text-7xl">
        TeSE — Transducteurs et Systemes d'Energie
      </h1>
      <p class="mt-8 max-w-3xl text-xl leading-9 text-slate-600">
        Nous developpons des methodes avancees pour la conception, la commande, la caracterisation et l'integration des systemes de conversion electromecanique d'energie, avec des applications dans la mobilite durable et les systemes embarques.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/fr/recherche/" class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-blue-700">
          Decouvrir nos recherches
        </a>
        <a href="/fr/contact/" class="rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-blue-600 hover:text-blue-600">
          Collaborer avec nous
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-600">Notre approche</p>
      <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">De la conception electromagnetique a la validation experimentale.</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">
        TeSE associe modelisation, optimisation, commande, instrumentation et essais multiphysiques pour concevoir des systemes electromecaniques efficaces, compacts et fiables.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {researchAxes.fr.slice(0, 3).map((axis) => (
        <Card title={axis.title} description={axis.description} />
      ))}
    </div>
  </section>

  <section class="bg-slate-950">
    <div class="mx-auto grid max-w-7xl gap-10 px-6 py-20 md:grid-cols-3">
      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
        <div class="text-4xl font-semibold text-white">5</div>
        <p class="mt-3 text-sm leading-6 text-slate-300">axes scientifiques couvrant conception, commande, caracterisation et applications mobilite.</p>
      </div>
      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
        <div class="text-4xl font-semibold text-white">3D</div>
        <p class="mt-3 text-sm leading-6 text-slate-300">vibrometrie laser et moyens experimentaux avances pour la correlation modele-essai.</p>
      </div>
      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
        <div class="text-4xl font-semibold text-white">FR / EN</div>
        <p class="mt-3 text-sm leading-6 text-slate-300">un site bilingue concu pour la visibilite scientifique et les collaborations internationales.</p>
      </div>
    </div>
  </section>
</BaseLayout>
