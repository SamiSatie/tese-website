---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Card from "../../components/Card.astro";
import { researchAxes } from "../../data/researchAxes";
---

<BaseLayout lang="en" title="Research | TeSE" description="Research axes of the TeSE group.">
  <PageHero
    eyebrow="Research"
    title="Electromechanical energy conversion for sustainable and embedded systems."
    description="TeSE develops models, methods and experimental tools to design, control and validate electrical machines, transducers and power conversion chains."
  />

  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {researchAxes.en.map((axis) => (
        <Card title={axis.title} description={axis.description} />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-24">
    <div class="rounded-[2rem] bg-white p-8 shadow-soft md:p-12">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-950">Scientific approach</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">
        Our research combines physics-based modelling, numerical optimization, experimental validation and system-level integration. We pay particular attention to the interactions between electromagnetic design, power electronics, control algorithms, thermal constraints and mechanical behavior.
      </p>
      <p class="mt-5 text-lg leading-8 text-slate-600">
        This integrated approach supports the development of compact, efficient and robust electromechanical systems for electric mobility, advanced air mobility, industrial actuation and embedded energy applications.
      </p>
    </div>
  </section>
</BaseLayout>
