---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Card from "../../components/Card.astro";
import { facilities } from "../../data/facilities";
---

<BaseLayout lang="en" title="Facilities | TeSE" description="Experimental facilities and platforms of TeSE.">
  <PageHero
    eyebrow="Facilities"
    title="Experimental platforms for testing, measuring and validating electromechanical systems."
    description="Our facilities support the complete research cycle: prototype, control, instrumentation, measurement, analysis and model-test correlation."
  />

  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {facilities.en.map((facility) => (
        <Card title={facility.name} description={facility.description} />
      ))}
    </div>
  </section>
</BaseLayout>
