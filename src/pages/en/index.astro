---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import { researchAxes } from "../../data/researchAxes";
---

<BaseLayout
  lang="en"
  title="TeSE — Transducers and Energy Systems"
  description="The TeSE research group develops advanced methods for electromechanical energy conversion systems."
>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(37,99,235,0.16),_transparent_35%),radial-gradient(circle_at_bottom_left,_rgba(6,182,212,0.14),_transparent_35%)]"></div>
    <div class="relative mx-auto max-w-7xl px-6 py-28 md:py-36">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-600">SATIE Research Laboratory</p>
      <h1 class="mt-6 max-w-5xl text-5xl font-semibold tracking-tight text-slate-950 md:text-7xl">
        TeSE — Transducers and Energy Systems
      </h1>
      <p class="mt-8 max-w-3xl text-xl leading-9 text-slate-600">
        We develop advanced methods for the design, control, characterization and integration of electromechanical energy conversion systems for sustainable mobility and embedded energy applications.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/en/research/" class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-soft transition hover:bg-blue-700">
          Discover our research
        </a>
        <a href="/en/contact/" class="rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-blue-600 hover:text-blue-600">
          Work with us
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-600">What we do</p>
      <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">From electromagnetic design to experimental validation.</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">
        TeSE brings together modelling, optimization, control, instrumentation and multiphysics testing to address the next generation of efficient, compact and reliable electromechanical systems.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {researchAxes.en.slice(0, 3).map((axis) => (
        <Card title={axis.title} description={axis.description} />
      ))}
    </div>
  </section>

  <section class="bg-slate-950">
    <div class="mx-auto grid max-w-7xl gap-10 px-6 py-20 md:grid-cols-3">
      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
        <div class="text-4xl font-semibold text-white">5</div>
        <p class="mt-3 text-sm leading-6 text-slate-300">core research axes covering design, control, characterization and mobility applications.</p>
      </div>
      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
        <div class="text-4xl font-semibold text-white">3D</div>
        <p class="mt-3 text-sm leading-6 text-slate-300">laser vibrometry and advanced experimental facilities for model-test correlation.</p>
      </div>
      <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
        <div class="text-4xl font-semibold text-white">FR / EN</div>
        <p class="mt-3 text-sm leading-6 text-slate-300">a bilingual academic website designed for international visibility and partnerships.</p>
      </div>
    </div>
  </section>
</BaseLayout>
