---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { people } from "../../data/people";
---

<BaseLayout lang="en" title="People | TeSE" description="Members of the TeSE research group.">
  <PageHero
    eyebrow="People"
    title="A multidisciplinary team in electrical engineering, modelling, control and experimentation."
    description="TeSE brings together faculty members, researchers, engineers, PhD students and postdoctoral researchers working on electromechanical energy systems."
  />

  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {people.en.map((person) => (
        <article class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-soft">
          <div class="mb-6 h-28 w-28 rounded-3xl bg-gradient-to-br from-blue-100 to-cyan-100"></div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">{person.group}</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">{person.name}</h2>
          <p class="mt-2 text-sm font-medium text-slate-700">{person.role}</p>
          <p class="mt-4 text-sm leading-7 text-slate-600">{person.topics}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
