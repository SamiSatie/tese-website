---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { projects } from "../../data/projects";
---

<BaseLayout lang="en" title="Projects and publications | TeSE" description="Research projects and selected publications of TeSE.">
  <PageHero
    eyebrow="Projects and publications"
    title="Collaborative research at the interface of electrical machines, control and sustainable mobility."
    description="This page presents selected research directions, collaborative projects and publication highlights. It can later be connected to HAL, ORCID or BibTeX exports."
  />

  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-6 lg:grid-cols-3">
      {projects.en.map((project) => (
        <article class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">{project.category}</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight text-slate-950">{project.title}</h2>
          <p class="mt-2 text-sm font-medium text-slate-500">{project.period}</p>
          <p class="mt-5 text-sm leading-7 text-slate-600">{project.summary}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 rounded-[2rem] bg-slate-950 p-8 text-white md:p-12">
      <h2 class="text-3xl font-semibold tracking-tight">Selected publications</h2>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">
        The production version of this page should include selected journal papers, conference papers, PhD theses and open-access links. A practical implementation is to maintain a BibTeX file or link this page to a HAL collection.
      </p>
    </div>
  </section>
</BaseLayout>
