---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { siteConfig } from "../../data/siteConfig";
---

<BaseLayout lang="en" title="Contact and join us | TeSE" description="Contact the TeSE research group.">
  <PageHero
    eyebrow="Contact and join us"
    title="Collaborate with TeSE or join the team."
    description="We welcome motivated students, PhD candidates, postdoctoral researchers and industrial partners interested in electromechanical energy conversion systems."
  />

  <section class="mx-auto grid max-w-7xl gap-8 px-6 py-16 md:grid-cols-2">
    <div class="rounded-[2rem] bg-white p-8 shadow-soft">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Opportunities</h2>
      <ul class="mt-6 space-y-4 text-sm leading-7 text-slate-600">
        <li>Master internships in electrical machines, modelling, control and experimental characterization.</li>
        <li>PhD projects on sustainable mobility, embedded energy systems and advanced electromechanical conversion.</li>
        <li>Postdoctoral research on modelling, optimization, diagnosis and multiphysics validation.</li>
        <li>Industrial collaborations and joint research projects.</li>
      </ul>
    </div>

    <div class="rounded-[2rem] bg-slate-950 p-8 text-white shadow-soft">
      <h2 class="text-2xl font-semibold tracking-tight">Contact</h2>
      <p class="mt-6 text-sm leading-7 text-slate-300">{siteConfig.lab}</p>
      <p class="mt-2 text-sm leading-7 text-slate-300">{siteConfig.institutions}</p>
      <p class="mt-2 text-sm leading-7 text-slate-300">{siteConfig.city}</p>
      <a class="mt-6 inline-flex rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950" href={`mailto:${siteConfig.contactEmail}`}>
        {siteConfig.contactEmail}
      </a>
    </div>
  </section>
</BaseLayout>
