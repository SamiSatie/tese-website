---
import { siteConfig } from "../data/siteConfig";
const { lang = "en" } = Astro.props;
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-6 py-12 md:grid-cols-3">
    <div>
      <div class="text-lg font-semibold text-slate-950">TeSE</div>
      <p class="mt-3 max-w-sm text-sm leading-6 text-slate-600">
        {lang === "fr"
          ? "Transducteurs et Systemes d'Energie — equipe de recherche du laboratoire SATIE."
          : "Transducers and Energy Systems — research group of the SATIE laboratory."}
      </p>
    </div>

    <div>
      <div class="text-sm font-semibold uppercase tracking-wide text-slate-950">
        {lang === "fr" ? "Institutions" : "Institutions"}
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-600">{siteConfig.institutions}</p>
    </div>

    <div>
      <div class="text-sm font-semibold uppercase tracking-wide text-slate-950">
        Contact
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-600">{siteConfig.city}</p>
      <a class="mt-2 block text-sm font-medium text-blue-600" href={`mailto:${siteConfig.contactEmail}`}>
        {siteConfig.contactEmail}
      </a>
    </div>
  </div>
</footer>
