---
const { eyebrow, title, description } = Astro.props;
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-600">{eyebrow}</p>
    <h1 class="mt-5 max-w-5xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl">{title}</h1>
    <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-600">{description}</p>
  </div>
</section>
