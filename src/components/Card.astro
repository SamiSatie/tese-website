---
const { title, description, eyebrow } = Astro.props;
---

<article class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-soft transition hover:-translate-y-1 hover:shadow-xl">
  {eyebrow && <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-blue-600">{eyebrow}</p>}
  <h3 class="text-xl font-semibold tracking-tight text-slate-950">{title}</h3>
  <p class="mt-4 text-sm leading-7 text-slate-600">{description}</p>
</article>
